# Copy this file to `.env` at the repository root. Root mise tasks load it for
# every command, including the agent tasks under agents/python. After editing,
# validate the result with `mise run config:check` (it masks secrets).
#
# Each variable below lists: purpose — default — which learning path needs it.

# ── Native Gemini path (Chapters 2-4) ────────────────────────────────────────
# API key for Google AI Studio. No default; required only for the hosted Gemini
# path. Unused by the fully local path and by Vertex AI.
GOOGLE_API_KEY=
# Model the agent asks for. Default: gemini-3.5-flash. The gateway path
# overrides this with a local Ollama model tag (e.g. qwen3:4b).
AGENT_MODEL=gemini-3.5-flash

# ── Fully local path: Ollama + agentgateway (Chapter 5) ──────────────────────
# Start Ollama and `mise run gateway:host` first, then uncomment this block.
# AGENT_GATEWAY_ENABLED routes model calls through the governed gateway; it
# requires OPENAI_BASE_URL and OPENAI_API_KEY (validated at startup).
# AGENT_GATEWAY_ENABLED=true
# AGENT_MODEL=qwen3:4b
# The gateway's OpenAI-compatible endpoint. Default port comes from the stable
# network contract (:4000).
# OPENAI_BASE_URL=http://127.0.0.1:4000/v1
# Not a real credential: a non-secret marker the OpenAI SDK requires even when
# gateway authentication is off.
# OPENAI_API_KEY=local-agentgateway
# Route the six read/runbook tools through the governed gateway MCP listener
# (:3000) instead of in-process stdio. Unset = local stdio MCP.
# AGENT_MCP_URL=http://127.0.0.1:3000/mcp
# Bearer token for a JWT/API-key-secured gateway MCP route (Chapter 5.5). Mint a
# demo token with `./infra/scripts/gateway-jwt.sh`. Unset for the open local route.
# AGENT_MCP_TOKEN=
# When the secured gateway serves TLS with a self-signed cert, point the OpenAI
# SDK and clients at it so certificate verification succeeds.
# SSL_CERT_FILE=infra/agentgateway/host/auth/gateway.crt

# ── Passwordless Vertex AI path (Chapters 5-7, optional GKE lab) ─────────────
# Local development uses Application Default Credentials; GKE uses Workload
# Identity Federation and mounts no service-account key.
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=agentops-open-course
# GOOGLE_CLOUD_LOCATION=global

# ── Data and A2A serving ─────────────────────────────────────────────────────
# Where the immutable seed dataset lives and where runtime state is copied.
# Defaults resolve inside the repository; override only for containers.
# AGENT_DATA_DIR=../data
# AGENT_STATE_DIR=.state
# Advertised A2A address (what the agent card publishes) — the bind address is
# always 0.0.0.0 inside `python -m agent.server`. Defaults: localhost:8080/http.
# AGENT_A2A_HOST=localhost
# AGENT_A2A_PORT=8080
# AGENT_A2A_PROTOCOL=http
# Upper bound on model calls a single A2A request may spend. Default: 12.
# AGENT_A2A_MAX_LLM_CALLS=12
# How long in-flight requests may drain after SIGTERM. Kubernetes'
# terminationGracePeriodSeconds must exceed this. Default: 10.
# AGENT_DRAIN_TIMEOUT_S=10

# ── Resilience (Chapter 4.5) ─────────────────────────────────────────────────
# Deadline for one model request, one governed MCP tool call, and the retry
# policy for transient failures. Guarded write actions are never retried.
# AGENT_MODEL_TIMEOUT_S=60
# AGENT_TOOL_TIMEOUT_S=30
# AGENT_MAX_RETRIES=2
# AGENT_RETRY_BACKOFF_S=0.5
# Cold-start deadline for the optional local embedding model (Chapter 3.4).
# AGENT_EMBEDDING_TIMEOUT_S=120

# ── Token budgets and cost attribution (Chapter 7.3) ─────────────────────────
# Hard per-session token budget; unset disables enforcement. Prices are per
# 1000 tokens in your billing currency: keep 0 for local Ollama, set your
# provider's published rates for hosted models (no vendor pricing is hardcoded).
# AGENT_MAX_TOKENS_PER_SESSION=50000
# AGENT_INPUT_PRICE_PER_1K=0
# AGENT_OUTPUT_PRICE_PER_1K=0

# ── Self-hosted telemetry and evaluation (Chapter 7) ─────────────────────────
# OTLP export for traces/metrics/logs. Unset = telemetry stays in-process.
# Message content capture stays off unless a learner explicitly accepts the
# privacy impact in an isolated environment.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_SERVICE_NAME=ops-copilot
# ADK_CAPTURE_MESSAGE_CONTENT_IN_SPANS=false
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=false
# MLflow tracking for evaluation runs and the prompt registry (Chapter 4.4).
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000
# MLFLOW_EXPERIMENT_NAME=ops-copilot
# MLFLOW_JUDGE_MODEL=qwen3:4b
