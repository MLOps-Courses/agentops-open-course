# Copy this file to `.env` at the repository root. Only explicit config,
# interactive, and live-evaluation tasks load it; install, check, and test tasks
# never inherit these values. Validate the result with `mise run config:check`,
# which masks secrets.
#
# Each variable below lists: purpose — default — which learning path needs it.

# ── Account-free default: Ollama + Qwen3 (Chapters 2-4) ─────────────────────
# The provider names the ADK client contract, not the network topology. The
# default OpenAI-compatible adapter calls Ollama directly.
AGENT_MODEL_PROVIDER=openai-compatible
AGENT_MODEL=qwen3:4b-instruct
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# Non-secret marker required by the OpenAI SDK; Ollama ignores it.
OPENAI_API_KEY=local-ollama

# ── Governed local path: Ollama + agentgateway (Chapter 5) ──────────────────
# Start Ollama and `mise run gateway:host`, then change only the base URL. The
# application-side provider remains `openai-compatible`.
# OPENAI_BASE_URL=http://127.0.0.1:4000/v1
# Route the six read/runbook tools through the governed gateway MCP listener
# (:3000) instead of in-process stdio. Unset = local stdio MCP.
# AGENT_MCP_URL=http://127.0.0.1:3000/mcp
# Bearer token for a JWT/API-key-secured gateway MCP route (Chapter 5.5). Mint a
# demo token with `./infra/scripts/gateway-jwt.sh`. Unset for the open local route.
# AGENT_MCP_TOKEN=
# When the secured gateway serves TLS with a self-signed cert, point the OpenAI
# SDK and clients at it so certificate verification succeeds. Agent tasks run
# from agents/python, so this path is relative to that working directory.
# SSL_CERT_FILE=../../infra/agentgateway/host/auth/ca-cert.pem

# ── Optional native Gemini / passwordless Vertex AI path ────────────────────
# Replace the provider and model above. AI Studio uses GOOGLE_API_KEY; Vertex
# uses Application Default Credentials locally and Workload Identity on GKE.
# AGENT_MODEL_PROVIDER=gemini
# AGENT_MODEL=gemini-3.5-flash
# GOOGLE_API_KEY=
# GOOGLE_GENAI_USE_ENTERPRISE=true
# GOOGLE_CLOUD_PROJECT=agentops-open-course
# GOOGLE_CLOUD_LOCATION=global

# ── Data and A2A serving ─────────────────────────────────────────────────────
# Optional immutable MLflow prompt-registry reference for host development and
# evaluation. The minimal production image omits MLflow and uses the committed
# instruction; unset also needs no MLflow server.
# AGENT_PROMPT_URI=prompts:/agentops-agent-instruction/2
# Where the immutable seed dataset lives and where runtime state is copied.
# Defaults resolve inside the repository; override only for containers.
# AGENT_DATA_DIR=../data
# AGENT_STATE_DIR=.state
# Advertised A2A address (what the agent card publishes) — the bind address is
# separate so host runs stay loopback-only. Kubernetes overrides the bind host
# to 0.0.0.0. Defaults: bind 127.0.0.1, advertise localhost:8080/http.
# AGENT_A2A_BIND_HOST=127.0.0.1
# AGENT_A2A_HOST=localhost
# AGENT_A2A_PORT=8080
# AGENT_A2A_PROTOCOL=http
# Upper bound on model calls a single A2A request may spend. Default: 12.
# AGENT_A2A_MAX_LLM_CALLS=12
# Token streaming is off because chunks weaken whole-message PII redaction.
# AGENT_A2A_STREAMING=false
# How long in-flight requests may drain after SIGTERM. Kubernetes'
# terminationGracePeriodSeconds must exceed this. Default: 10.
# AGENT_DRAIN_TIMEOUT_S=10

# ── Resilience (Chapter 4.5) ─────────────────────────────────────────────────
# Deadline for one model request, one governed MCP tool call, and the retry
# policy for transient failures. Guarded write actions are never retried.
# AGENT_MODEL_TIMEOUT_S=60
# AGENT_TOOL_TIMEOUT_S=30
# AGENT_MAX_RETRIES=2
# AGENT_RETRY_BACKOFF_S=0.5
# Spotlight and neutralize prompt-injection markers in untrusted tool output.
# Default: true.
# AGENT_SANITIZE_TOOL_OUTPUT=true
# Optional semantic retrieval through local Ollama embeddings. Keyword
# retrieval remains the deterministic default.
# AGENT_SEMANTIC_RETRIEVAL=false
# AGENT_EMBEDDINGS_URL=http://127.0.0.1:11434
# AGENT_EMBEDDING_MODEL=nomic-embed-text
# Cold-start deadline for the optional local embedding model (Chapter 3.4).
# AGENT_EMBEDDING_TIMEOUT_S=120
# Bounded conversation history (Chapter 3.4). Unset sends ADK's full session
# history every turn; a positive value keeps only that many recent messages and
# replaces older ones with one compact note. Deterministic and model-free.
# AGENT_MAX_HISTORY_MESSAGES=40

# ── Token budgets and cost attribution (Chapter 7.3) ─────────────────────────
# Hard per-session token budget; unset disables enforcement. Prices are per
# 1000 tokens in your billing currency: keep 0 for local Ollama, set your
# provider's published rates for hosted models (no vendor pricing is hardcoded).
# AGENT_MAX_TOKENS_PER_SESSION=50000
# AGENT_INPUT_PRICE_PER_1K=0
# AGENT_OUTPUT_PRICE_PER_1K=0

# ── Self-hosted telemetry and evaluation (Chapter 7) ─────────────────────────
# OTLP export for traces/metrics/logs. Unset = telemetry stays in-process.
# Message content capture stays off unless a learner explicitly accepts the
# privacy impact in an isolated environment.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_SERVICE_NAME=agentops-agent
# ADK_CAPTURE_MESSAGE_CONTENT_IN_SPANS=false
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=false
# MLflow tracking for evaluation runs and the prompt registry (Chapter 4.4).
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000
# MLFLOW_EXPERIMENT_NAME=agentops-agent
# MLFLOW_JUDGE_MODEL=qwen3:4b-instruct
# MLFLOW_JUDGE_BASE_URL=http://127.0.0.1:4000/v1
# MLFLOW_JUDGE_API_KEY=local-ollama
