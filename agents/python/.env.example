# Native Gemini (Chapters 2-4). Create a key at https://ai.google.dev
# Prefer the global .env at the repo root; this per-track file overrides it if present.
GOOGLE_API_KEY=

# Optional: override the model (defaults to gemini-3.5-flash).
# AGENT_MODEL=gemini-3.5-flash

# Alternatively, use Vertex AI with Application Default Credentials instead of an API key:
# GOOGLE_GENAI_USE_VERTEXAI=true

# Where the bundled Ops Copilot dataset lives (default: the repo's agents/data).
# AGENT_DATA_DIR=/absolute/path/to/agents/data

# Observability (Ch. 7): point at an OTLP collector to export traces/metrics/logs.
# ADK auto-instruments model and tool calls; `adk web` also shows traces in its UI.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=ops-copilot
