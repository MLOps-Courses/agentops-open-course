# Component-local reference for every AgentOps Agent runtime setting. Live and
# configuration tasks load ../../.env explicitly; offline gates load no dotenv.
# For independent execution, export selected variables instead of copying this
# file into the project. Validate with `mise run config:check`.

# Account-free default: ADK's OpenAI-compatible adapter calls Ollama directly.
# Change only OPENAI_BASE_URL to http://127.0.0.1:4000/v1 when agentgateway is
# running; the application-side provider remains `openai-compatible`.
AGENT_MODEL_PROVIDER=openai-compatible
AGENT_MODEL=qwen3:4b-instruct
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_API_KEY=local-ollama

# Optional native Gemini/Vertex path. Replace the provider/model above; AI
# Studio uses GOOGLE_API_KEY, while Vertex uses ADC plus the enterprise fields.
# AGENT_MODEL_PROVIDER=gemini
# AGENT_MODEL=gemini-3.5-flash
# GOOGLE_API_KEY=
# GOOGLE_GENAI_USE_ENTERPRISE=true
# GOOGLE_CLOUD_PROJECT=agentops-open-course
# GOOGLE_CLOUD_LOCATION=global

# Prompt, MCP, data, and serving. AGENT_PROMPT_URI is a host dev/eval feature;
# the minimal production image omits MLflow and uses the committed instruction.
# AGENT_PROMPT_URI=prompts:/agentops-agent-instruction/2
# AGENT_MCP_URL=http://127.0.0.1:3000/mcp
# AGENT_MCP_TOKEN=
# Secured host gateway CA, relative to this component's task working directory.
# SSL_CERT_FILE=../../infra/agentgateway/host/auth/ca-cert.pem
# AGENT_DATA_DIR=../data
# AGENT_STATE_DIR=.state
# AGENT_A2A_BIND_HOST=127.0.0.1
# AGENT_A2A_HOST=localhost
# AGENT_A2A_PORT=8080
# AGENT_A2A_PROTOCOL=http
# AGENT_A2A_MAX_LLM_CALLS=12
# AGENT_A2A_STREAMING=false
# AGENT_DRAIN_TIMEOUT_S=10

# Resilience and untrusted-content handling.
# AGENT_MODEL_TIMEOUT_S=60
# AGENT_TOOL_TIMEOUT_S=30
# AGENT_MAX_RETRIES=2
# AGENT_RETRY_BACKOFF_S=0.5
# AGENT_SANITIZE_TOOL_OUTPUT=true

# Optional local semantic retrieval.
# AGENT_SEMANTIC_RETRIEVAL=false
# AGENT_EMBEDDINGS_URL=http://127.0.0.1:11434
# AGENT_EMBEDDING_MODEL=nomic-embed-text
# AGENT_EMBEDDING_TIMEOUT_S=120

# Token budgets and cost attribution.
# AGENT_MAX_TOKENS_PER_SESSION=50000
# AGENT_INPUT_PRICE_PER_1K=0
# AGENT_OUTPUT_PRICE_PER_1K=0

# Self-hosted telemetry and evaluation.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_SERVICE_NAME=agentops-agent
# ADK_CAPTURE_MESSAGE_CONTENT_IN_SPANS=false
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=false
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000
# MLFLOW_EXPERIMENT_NAME=agentops-agent
# MLFLOW_JUDGE_MODEL=qwen3:4b-instruct
# MLFLOW_JUDGE_BASE_URL=http://127.0.0.1:4000/v1
# MLFLOW_JUDGE_API_KEY=local-ollama
