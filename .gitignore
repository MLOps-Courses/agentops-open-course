# https://git-scm.com/docs/gitignore

# Environments
.env
**/.venv/

# Python caches and build output
**/__pycache__/
**/*.py[co]
**/.pytest_cache/
**/.ruff_cache/
**/.ty_cache/
**/dist/
.coverage
htmlcov/

# Node
**/node_modules/

# Docs site (Zensical output + build cache)
/site/
/.cache/

# Scratch
.agents/tmp/
tmp/

# OpenTofu local state and provider caches
**/.terraform/
**/.terraform.tfstate.lock.info
**/*.tfstate
**/*.tfstate.*
**/tfplan
**/*.tfplan
**/.tflint.d/

# ADK eval history (generated by `adk eval`)
**/.adk/
**/.state/

# SQLite state snapshots (generated by infra/scripts/backup-state.sh)
**/.state-backups/

# MLflow local tracking store + runs (generated by `mise run eval:mlflow`, Ch. 4.4/7.0)
**/mlflow.db
**/mlruns/

# Demo-only gateway auth material: self-signed TLS certificate plus JWT signing
# key/JWKS generated by infra/scripts/gateway-{tls,jwt}.sh (Ch. 5.5)
infra/agentgateway/host/auth/

# SOPS lab material (infra/scripts/secrets.sh, Ch. 6.5): only ciphertext under
# infra/**/secrets/ is committed; age private keys and decrypted output are not
infra/secrets/
**/*.agekey
**/*.dec.yaml
