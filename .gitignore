# https://git-scm.com/docs/gitignore

# Environments
.env
**/.venv/

# Python caches
**/__pycache__/
**/*.py[co]
**/.pytest_cache/
**/.ruff_cache/
**/.ty_cache/
.coverage
htmlcov/

# Go artifacts
**/bin/
coverage.out

# Node
**/node_modules/

# Docs site (Zensical output + build cache)
/site/
/.cache/

# Scratch
.agents/tmp/
tmp/

# ADK eval history (generated by `adk eval`)
**/.adk/
