# https://git-scm.com/docs/gitignore

# Environments
.env
**/.venv/

# Python caches and build output
**/__pycache__/
**/*.py[co]
**/.pytest_cache/
**/.ruff_cache/
**/.ty_cache/
**/dist/
.coverage
htmlcov/

# Node
**/node_modules/

# Docs site (Zensical output + build cache)
/site/
/.cache/

# Scratch
.agents/tmp/
tmp/

# ADK eval history (generated by `adk eval`)
**/.adk/

# MLflow local tracking store + runs (generated by `mise run eval:mlflow`, Ch. 4.4/7.0)
**/mlflow.db
**/mlruns/

# garak red-team run logs/reports (generated by `mise run redteam`, Ch. 4.6)
**/garak_runs/
**/garak.*.jsonl
**/*.report.jsonl
